@using NetCoreAı.ApiConsumeUi.Dtos
@model CreateCustomerDto

@{
    ViewData["Title"] = "Yeni Müşteri Ekle";
    // Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Yeni Müşteri Kayıt Formu</h4>
        </div>
        <div class="card-body">
            <form method="post">
                <div class="form-group mb-3">
                    <label class="form-label font-weight-bold">Müşteri Adı</label>
                    <input type="text" class="form-control" name="customerName" placeholder="Adını giriniz..." required />
                </div>

                <div class="form-group mb-3">
                    <label class="form-label font-weight-bold">Müşteri Soyadı</label>
                    <input type="text" class="form-control" name="custormerSurName" placeholder="Soyadını giriniz..." required />
                </div>

                <div class="form-group mb-3">
                    <label class="form-label font-weight-bold">Bakiye</label>
                    <input type="number" class="form-control" name="customerBalance" placeholder="0.00" step="0.01" required />
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success px-4">
                        <i class="fas fa-save"></i> Kaydet
                    </button>
                    <a href="/Customer/CustomerList" class="btn btn-secondary px-4">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>